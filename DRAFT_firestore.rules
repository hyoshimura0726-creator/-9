rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidDateId(id) { 
      return id is string && id.size() == 10 && id.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$'); 
    }

    function isValidDailyLog(data, userId) {
      return data.keys().hasAll(['ownerId', 'updatedAt']) 
        && data.ownerId == request.auth.uid
        && data.ownerId == userId
        && data.updatedAt == request.time
        && (!('good' in data) || (data.good is string && data.good.size() <= 10000))
        && (!('bad' in data) || (data.bad is string && data.bad.size() <= 10000))
        && (!('gratitude' in data) || (data.gratitude is string && data.gratitude.size() <= 10000))
        && (!('aiComment' in data) || (data.aiComment is string && data.aiComment.size() <= 10000));
    }

    match /users/{userId}/logs/{logDate} {
      // Must be owner. No blanket reads.
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidDateId(logDate)
        && isValidDailyLog(incoming(), userId)
        && incoming().keys().hasOnly(['ownerId', 'updatedAt', 'good', 'bad', 'gratitude', 'aiComment']);
        
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidDailyLog(incoming(), userId)
        && incoming().ownerId == existing().ownerId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['good', 'bad', 'gratitude', 'aiComment', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
